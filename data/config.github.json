    "twitter": {
      "enabled": false,
      "apify_token_env": "APIFY_TOKEN",
      "users": [
        "sama",
        "gdb",
        "karpathy",
        "ylecun",
        "AndrewYNg",
        "demishassabis",
        "swyx",
        "nearcyan"
      ],
      "fetch_limit": 100,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 20
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": [
        {
          "name": "ai-megacaps",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "ai-equities",
          "symbols": [
            "NVDA",
            "MSFT",
            "GOOGL",
            "META",
            "AMZN",
            "TSLA",
            "AMD",
            "AVGO"
          ]
        }
      ]
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "All",
        "Python",
        "TypeScript",
        "Rust",
        "Jupyter Notebook"
      ],
      "keywords": [
        "ai",
        "llm",
        "agent",
        "rag",
        "diffusion",
        "transformer",
        "mcp",
        "inference",
        "model"
      ],
      "min_stars": 10,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "text": "Horizon AI Daily #{date}\n\n#{message_title}\n\n#{summary?limit=3500&split=---}"
    },
    "headers": ""
  }
